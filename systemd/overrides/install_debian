echo "deb-src http://deb.debian.org/debian forky main" >> /etc/apt/sources.list
tee /etc/apt/sources.list.d/localrepo.list <<'EOF' 
deb [trusted=yes] file:/localrepo ./
EOF
#dpkg-reconfigure locales
sed -i 's/^# *\(en_US.UTF-8\)/\1/' /etc/locale.gen
sed -i 's/^# *\(ru_RU.UTF-8\)/\1/' /etc/locale.gen
locale-gen
export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get -y dist-upgrade
apt-get -y install \
systemd \
xfce4-terminal \
openssh-server \
less \
socat \
minicom
useradd -u 1001 -m -s /bin/bash maxuser
echo 'root:12345' | chpasswd
echo 'maxuser:12345' | chpasswd
sed -i 's/#Port\ 22/Port\ 2022/g' /etc/ssh/sshd_config
sed -i 's/#PermitRootLogin\ prohibit-password/PermitRootLogin\ yes/g' /etc/ssh/sshd_config
