rm -f /rosa-base.desktop
tee /etc/yum.repos.d/max.repo <<'EOF'
[max]
name=MAX Desktop
baseurl=https://download.max.ru/linux/rpm/el/9/$basearch
enabled=1
gpgcheck=1
repo_gpgcheck=1
gpgkey=https://download.max.ru/linux/rpm/public.asc
sslverify=1
metadata_expire=300
EOF
rpm --import https://download.max.ru/linux/rpm/public.asc
dnf -y update
dnf clean all
dnf -y install max
useradd -u 1000 -m -s /bin/bash maxuser
ldd /usr/share/max/bin/max|grep found
ldd /usr/share/max/bin/max-service/bin/max-service|grep found
ldd /usr/share/max/plugins/platforms/libqxcb.so |grep found
chmod 755 /usr/share/max/plugins/platforms/libqxcb.so
ls -l /usr/share/max/plugins/platforms/libqxcb.so
